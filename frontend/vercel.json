{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": "vite",
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "rewrites": [
    { "source": "/api/(.*)", "destination": "https://farmerp-backend-production.up.railway.app/api/$1" },
    { "source": "/media/(.*)", "destination": "https://farmerp-backend-production.up.railway.app/media/$1" },
    { "source": "/((?!assets/).*)", "destination": "/index.html" }
  ]
}
