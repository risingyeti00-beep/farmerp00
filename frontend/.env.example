# ═══════════════════════════════════════════════════════════════════════════
# FarmERP Pro — Frontend Environment Variables
# ═══════════════════════════════════════════════════════════════════════════
#
# Copy this file to .env for local development:
#   cp .env.example .env
#
# For production (Vercel), set these in your Vercel Dashboard:
#   https://vercel.com/your-team/farmerp1/settings/environment-variables
#
# ═══════════════════════════════════════════════════════════════════════════

# ── API Configuration ───────────────────────────────────────────────────
# 🚨 CRITICAL: In production on Vercel, LEAVE THIS UNSET (blank/empty).
#
# When VITE_API_URL is blank, API requests go to the SAME origin as the
# frontend (farmerp1.vercel.app). Vercel then PROXIES them to Railway
# via vercel.json rewrites — this means NO CORS errors.
#
# ❌ If you set this to the Railway URL, the browser makes DIRECT
#    cross-origin requests, which WILL trigger CORS errors.
#
# Only set this if you need to bypass the Vercel proxy for debugging.
# VITE_API_URL=https://farmerp-backend-production.up.railway.app

# ── WebSocket Configuration (for real-time notifications & GPS) ─────────
# ⚠️  Vercel does NOT proxy WebSocket connections. So WebSocket URLs must
#     point directly to the Railway backend.
#
# Set this in Vercel env vars for production WebSocket support.
# If not set, the app will use the default Railway WebSocket URL.
# VITE_WS_URL=wss://farmerp-backend-production.up.railway.app

# ── Supabase (for realtime database features) ───────────────────────────
# Required for the app. Get these from Supabase Dashboard → Settings → API
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# ── Feature Flags ───────────────────────────────────────────────────────
# Set to "false" to disable WebSocket and use HTTP polling instead
# VITE_ENABLE_WEBSOCKET=true

# ── Google Maps (optional) ──────────────────────────────────────────────
# If blank, falls back to OpenStreetMap (Leaflet)
# VITE_GOOGLE_MAPS_API_KEY=
