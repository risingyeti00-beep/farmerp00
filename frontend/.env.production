# Copy these into the Vercel project's Environment Variables (Production).
# Point them at your deployed Railway backend.

# Backend API origin (no trailing slash). Calls go to <VITE_API_URL>/api/v1
VITE_API_URL=https://farmerp-backend-production.up.railway.app

# WebSocket origin for live GPS tracking (wss = secure). Origin only — the app
# appends the /ws/... path itself.
VITE_WS_URL=wss://farmerp-backend-production.up.railway.app

# Optional: existing keys already used by the app
# VITE_LOCATION_TRACKING_API_KEY=...