# ═══════════════════════════════════════════════════════════════════════════
# FarmERP Pro — Backend Environment Variables
# ═══════════════════════════════════════════════════════════════════════════
#
# Copy this file to .env for local development:
#   cp .env.example .env
#
# For production (Railway), set these in your Railway Dashboard:
#   https://railway.app/project/<your-project>/variables
#
# ═══════════════════════════════════════════════════════════════════════════

# ── Django Core ─────────────────────────────────────────────────────────
SECRET_KEY=django-insecure-change-this-to-a-random-secret-key
DEBUG=False

# Comma-separated list of allowed hosts
ALLOWED_HOSTS=farmerp-backend-production.up.railway.app,localhost,127.0.0.1,.vercel.app

# ── Database (Postgres via Supabase) ────────────────────────────────────
# Get this from Supabase Dashboard → Project Settings → Database
# Use the connection pooler URL (port 6543) for production:
DATABASE_URL=postgresql://postgres.your-ref:password@aws-0-ap-southeast-2.pooler.supabase.com:6543/postgres

# ── Supabase Storage ────────────────────────────────────────────────────
SUPABASE_URL=https://favafuvuglsorwmezggd.supabase.co
SUPABASE_SERVICE_KEY=your-service-role-key-here
SUPABASE_STORAGE_BUCKET=uploads

# ── CORS (Comma-separated, appends to defaults) ─────────────────────────
# The defaults already include localhost and https://farmerp1.vercel.app
# Only add NEW origins here that are NOT already in the defaults:
CORS_ALLOWED_ORIGINS=
CSRF_TRUSTED_ORIGINS=

# ── Email (Gmail SMTP) ──────────────────────────────────────────────────
# For forgot-password OTP emails
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
DEFAULT_FROM_EMAIL=

# ── LocationIQ (reverse geocoding) ─────────────────────────────────────
# Get a free API key from https://locationiq.com/
LOCATIONIQ_API_KEY=

# ── Google Sheets mirror ────────────────────────────────────────────────
# Supabase remains the primary database; every committed write is mirrored
# to your EXISTING Google Spreadsheet (one worksheet per table). The app
# never creates a spreadsheet.
#
# 1. Create a Google Cloud project → enable "Google Sheets API" and
#    "Google Drive API".
# 2. Create a Service Account → download its JSON key.
#    - Locally: drop the key into backend/credentials/ (auto-detected,
#      git-ignored) — no variable needed.
#    - Production (Railway): paste the ENTIRE JSON on one line below.
# 3. Share your spreadsheet with the service account's client_email
#    (role: Editor) and set GOOGLE_SPREADSHEET_ID from the sheet URL.
# 4. Verify:   python manage.py sheets_check
# 5. Run once: python manage.py sheets_backfill   (migrates existing data)
GOOGLE_SHEETS_SYNC_ENABLED=True
GOOGLE_SERVICE_ACCOUNT_JSON=
# GOOGLE_SERVICE_ACCOUNT_FILE=C:/path/to/service-account.json
# ID of your existing spreadsheet (docs.google.com/spreadsheets/d/<ID>/edit)
GOOGLE_SPREADSHEET_ID=

# ── Optional: S3 Storage (instead of Supabase) ─────────────────────────
# Set USE_S3=true and configure AWS credentials to use S3 instead of Supabase
USE_S3=false
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_STORAGE_BUCKET_NAME=
# AWS_S3_REGION_NAME=
